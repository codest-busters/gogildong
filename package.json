{
  "name": "bori-and-children-monorepo",
  "version": "1.0.0",
  "description": "보리와 아이들 - 고양이 목격/등록 앱 모노레포",
  "private": true,
  "workspaces": [
    "back",
    "front",
    "shared"
  ],
  "scripts": {
    "install:all": "npm install && npm run install:back && npm run install:front",
    "install:back": "cd back && npm install",
    "install:front": "cd front && npm install",
    "dev:back": "cd back && npm run start:dev",
    "dev:front": "cd front && npx react-native start",
    "dev:android": "cd front && npx react-native run-android",
    "dev:ios": "cd front && npx react-native run-ios",
    "build:back": "cd back && npm run build",
    "build:android": "cd front && cd android && ./gradlew assembleRelease",
    "clean:all": "rm -rf node_modules back/node_modules front/node_modules shared/node_modules",
    "postinstall": "npx husky install"
  },
  "devDependencies": {
    "@types/react-native-vector-icons": "^6.4.18",
    "husky": "^8.0.0",
    "lint-staged": "^13.0.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-native-community/geolocation": "^3.4.0",
    "@react-native-firebase/app": "^23.3.1",
    "@react-native-firebase/auth": "^23.3.1",
    "@react-navigation/bottom-tabs": "^7.4.7",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.26",
    "react-hook-form": "^7.62.0",
    "react-native-config": "^1.5.9",
    "react-native-fast-tflite": "^1.6.1",
    "react-native-image-picker": "^8.2.1",
    "react-native-image-resizer": "^1.4.5",
    "react-native-maps": "^1.26.1",
    "react-native-paper": "^5.14.5",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "^4.16.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-vision-camera": "^4.7.2",
    "zod": "^4.1.8",
    "zustand": "^5.0.8"
  }
}
